{
  "name": "MCP File Server",
  "description": "Model Context Protocol server for file management and HA CLI commands in Home Assistant",
  "version": "1.3.0",
  "slug": "mcp_file_server",
  "url": "https://github.com/bmw93/ha-addon-mcp-file-server",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "services",
  "boot": "auto",
  "hassio_api": true,
  "hassio_role": "manager",
  "homeassistant_api": true,
  "auth_api": true,
  "host_network": false,
  "ports": { "6789/tcp": 6789 },
  "ports_description": { "6789/tcp": "MCP Server HTTP/SSE endpoint" },
  "map": ["config:rw", "share:rw", "addons:rw", "backup:rw", "media:rw"],
  "watchdog": "http://[HOST]:[PORT:6789]/health",
  "options": {
    "port": 6789,
    "api_key": "",
    "allowed_dirs": ["/config", "/share", "/addons", "/backup", "/media"],
    "read_only": false,
    "max_file_size_mb": 10,
    "enable_ha_cli": true
  },
  "schema": {
    "port": "port",
    "api_key": "str?",
    "allowed_dirs": ["str"],
    "read_only": "bool",
    "max_file_size_mb": "int(1,100)",
    "enable_ha_cli": "bool"
  }
}